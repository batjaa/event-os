# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit real credentials (this is a PUBLIC repo)
.env
.env.local
.env.production
.env.development
.env*.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env.local
.env
.gstack/
.claude/worktrees
public/uploads/

# OpenClaw — only SKILL.md is safe to commit, never config/env/tokens
openclaw/.env
openclaw/*.json
openclaw/*.json5
openclaw/*.yaml
openclaw/*.yml

# SQLite
*.db
*.db-wal
*.db-shm

# Playwright
/test-results/
/playwright-report/
