# Copy this file to .env.local and fill in real values
# NEVER commit .env.local — it's in .gitignore

# Database dialect: "postgresql" (default) or "sqlite"
DB_DIALECT="postgresql"

# PostgreSQL connection (used when DB_DIALECT=postgresql)
DATABASE_URL="postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres"

# SQLite file path (used when DB_DIALECT=sqlite)
# SQLITE_PATH="local.db"

# Auth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# OpenClaw service token (for Telegram agent → API communication)
SERVICE_TOKEN="generate-a-random-token-here"

# LLM Provider for agent chat panel
# Options: "gemini" (default), "xai" (Grok), "ollama" (local)
LLM_PROVIDER="gemini"

# Gemini (default — generous free tier at ai.google.dev)
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash"

# xAI / Grok (fast, $25 free credits at console.x.ai)
# XAI_API_KEY="your-xai-api-key"
# XAI_MODEL="grok-3-mini"

# Z.AI / GLM (good multilingual, credits at z.ai)
# ZAI_API_KEY="your-zai-api-key"
# ZAI_MODEL="glm-4.5"

# Ollama (local — free, run `ollama pull qwen3.5:4b` first)
# OLLAMA_URL="http://localhost:11434"
# OLLAMA_MODEL="qwen3.5:4b"
