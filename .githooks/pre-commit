#!/bin/bash
# Pre-commit hook: scan staged files for secrets before committing
# This is a PUBLIC repo — zero tolerance for leaked credentials.

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Scanning for secrets before commit...${NC}"

# Patterns that indicate real secrets (not schema definitions or placeholders)
PATTERNS=(
  'sk-[a-zA-Z0-9]{20,}'           # OpenAI/Stripe secret keys
  'pk_live_[a-zA-Z0-9]+'          # Stripe publishable keys
  'ghp_[a-zA-Z0-9]{30,}'          # GitHub personal access tokens
  'gho_[a-zA-Z0-9]{30,}'          # GitHub OAuth tokens
  'AKIA[A-Z0-9]{16}'              # AWS access key IDs
  'eyJ[a-zA-Z0-9_-]{50,}'         # JWT tokens (long base64)
  'xoxb-[0-9]+-[a-zA-Z0-9]+'     # Slack bot tokens
  'postgresql://[^"]*:[^@"]+@[^"]*supabase' # Real Supabase connection strings
)

FOUND_SECRETS=0

for pattern in "${PATTERNS[@]}"; do
  # Only scan staged files (what's about to be committed)
  MATCHES=$(git diff --cached --diff-filter=ACM -U0 | grep -E "^\+" | grep -vE "^\+\+\+" | grep -oE "$pattern" 2>/dev/null)
  if [ -n "$MATCHES" ]; then
    echo -e "${RED}BLOCKED: Found potential secret matching pattern: $pattern${NC}"
    echo "$MATCHES" | head -3
    FOUND_SECRETS=1
  fi
done

# Check for .env files being committed (except .env.example)
ENV_FILES=$(git diff --cached --name-only | grep -E '\.env($|\.)' | grep -v '\.env\.example$')
if [ -n "$ENV_FILES" ]; then
  echo -e "${RED}BLOCKED: Attempting to commit env file(s):${NC}"
  echo "$ENV_FILES"
  FOUND_SECRETS=1
fi

# Check for common secret file patterns
SECRET_FILES=$(git diff --cached --name-only | grep -iE '(credentials|secret|private.*key|\.pem$|\.key$|id_rsa)')
if [ -n "$SECRET_FILES" ]; then
  echo -e "${RED}BLOCKED: Attempting to commit potentially sensitive file(s):${NC}"
  echo "$SECRET_FILES"
  FOUND_SECRETS=1
fi

if [ "$FOUND_SECRETS" -eq 1 ]; then
  echo ""
  echo -e "${RED}COMMIT BLOCKED: Potential secrets detected.${NC}"
  echo -e "This is a PUBLIC repository. Review the files above."
  echo -e "If these are false positives, use: git commit --no-verify"
  exit 1
fi

echo -e "${GREEN}Secret scan passed. No credentials found.${NC}"

# ─── Run unit tests ─────────────────────────────────────
echo -e "${YELLOW}Running unit tests...${NC}"

if npx vitest run tests/unit --reporter=dot 2>&1 | tail -5; then
  TESTS_EXIT=${PIPESTATUS[0]}
else
  TESTS_EXIT=1
fi

if [ "$TESTS_EXIT" -ne 0 ]; then
  echo ""
  echo -e "${RED}COMMIT BLOCKED: Unit tests failed.${NC}"
  echo -e "Fix the failing tests before committing."
  echo -e "To skip: git commit --no-verify"
  exit 1
fi

echo -e "${GREEN}All checks passed.${NC}"
exit 0
